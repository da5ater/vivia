{
  "extends": "@workspace/typescript-config/nextjs.json",
  "compilerOptions": {
    "types": ["node"],
    "baseUrl": ".",
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@/*": ["./*"],
      "@workspace/ui/*": ["../../packages/ui/src/*"],
      "@workspace/backend/convex/*": ["../../packages/backend/convex/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "app/.next/types/**/*.ts",
    "next-env.d.ts",
    "next.config.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
